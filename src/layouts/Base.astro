---
import "@fontsource/ibm-plex-sans/400.css";
import "@fontsource/ibm-plex-sans/500.css";
import "@fontsource/ibm-plex-sans/600.css";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/500.css";
import "../styles/global.css";
import { content, type Lang } from "../i18n/content";

interface Props {
  lang: Lang;
  title?: string;
  canonicalPath?: string;
}
const { lang, title, canonicalPath } = Astro.props;
const t = content[lang];
const pageTitle = title ?? t.meta.title;
const canonical = canonicalPath
  ? `https://piyanomini.com${canonicalPath}`
  : lang === "tr"
    ? "https://piyanomini.com/"
    : "https://piyanomini.com/en/";
---

<!doctype html>
<html lang={t.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />
    <title>{pageTitle}</title>
    <meta name="description" content={t.meta.description} />

    <!-- Dil tercihini hatırla. Çerez = son seçilen dil; çıplak domain (/) bu
         çereze bakarak son seçilen dili açar (vercel.json).
         - Sayfa yüklenince çerezi bu sayfanın diline yazar (doğrudan giriş / yer imi).
         - Bir bağlantıya tıklanınca, gidilecek sayfanın diline göre çerezi tıklama
           anında günceller; böylece değer-duyarlı yönlendirme TR/EN linkini geri sektirmez. -->
    <script is:inline define:vars={{ lang }}>
      (function () {
        var ATTRS = "; path=/; max-age=31536000; samesite=lax";
        document.cookie = "pref-lang=" + lang + ATTRS;
        document.addEventListener(
          "click",
          function (e) {
            var a = e.target && e.target.closest ? e.target.closest("a[href]") : null;
            if (!a) return;
            var url;
            try { url = new URL(a.href, location.href); } catch (_) { return; }
            if (url.origin !== location.origin) return;
            var en = url.pathname === "/en" || url.pathname.indexOf("/en/") === 0;
            document.cookie = "pref-lang=" + (en ? "en" : "tr") + ATTRS;
          },
          true
        );
      })();
    </script>
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#fcfbf7" />

    <!-- hreflang -->
    <link rel="alternate" hreflang="tr" href="https://piyanomini.com/" />
    <link rel="alternate" hreflang="en" href="https://piyanomini.com/en/" />
    <link rel="alternate" hreflang="x-default" href="https://piyanomini.com/" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={t.meta.title} />
    <meta property="og:description" content={t.meta.description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://piyanomini.vercel.app/og-image.png" />
    <meta property="og:image:width" content="1024" />
    <meta property="og:image:height" content="1024" />
    <meta property="og:locale" content={lang === "tr" ? "tr_TR" : "en_US"} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:image" content="https://piyanomini.vercel.app/og-image.png" />
  </head>
  <body>
    <a href="#main" class="sr-only">{lang === "tr" ? "İçeriğe atla" : "Skip to content"}</a>
    <slot />
  </body>
</html>
