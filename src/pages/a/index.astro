---
// Ödev landing sayfası — YALNIZ uygulama yüklü DEĞİLKEN görünür.
// (Yüklüyse universal link iOS tarafından yakalanır, app açılır, bu sayfa hiç yüklenmez.)
// Tamamen statik: payload URL'in `?d=` query'sinde; çözme client-side, sunucu yok.
const scheme = "piyanomini"; // custom scheme fallback (piyanomini://a?d=…)
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Piyanomini · Ödev</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Piyanomini · Ödev" />
    <meta property="og:description" content="Öğretmeninin paylaştığı alıştırma — Piyanomini'de aç." />
    <meta property="og:image" content="https://piyanomini.vercel.app/og-image.png" />
    <meta property="og:image:width" content="1024" />
    <meta property="og:image:height" content="1024" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:image" content="https://piyanomini.vercel.app/og-image.png" />
    <style>
      :root { color-scheme: light dark; }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        min-height: 100svh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #fff;
        color: #111;
        font-family: "IBM Plex Sans", -apple-system, system-ui, sans-serif;
        padding: 32px;
      }
      @media (prefers-color-scheme: dark) {
        body { background: #111; color: #f4f4f4; }
        .btn-secondary { color: #f4f4f4; }
      }
      main { width: 100%; max-width: 420px; text-align: center; }
      .brand { font-size: 13px; letter-spacing: 2px; text-transform: uppercase; opacity: .5; font-family: "IBM Plex Mono", ui-monospace, monospace; }
      h1 { font-size: 28px; font-weight: 600; margin: 14px 0 6px; }
      .module { font-size: 15px; opacity: .7; margin: 0 0 2px; }
      .note { font-size: 14px; opacity: .55; margin: 10px 0 0; }
      .rule { height: 1.5px; background: currentColor; opacity: .9; margin: 28px 0; }
      .btn {
        display: block; width: 100%; padding: 16px; font-size: 16px;
        text-decoration: none; border: none; cursor: pointer;
        font-family: inherit;
      }
      .btn-primary { background: #111; color: #fff; }
      @media (prefers-color-scheme: dark) { .btn-primary { background: #f4f4f4; color: #111; } }
      .btn-secondary { background: transparent; color: #111; opacity: .6; margin-top: 8px; font-size: 14px; }
      .hint { font-size: 12px; opacity: .45; margin-top: 22px; line-height: 1.5; }
    </style>
  </head>
  <body>
    <main>
      <p class="brand">Piyanomini</p>
      <h1 id="title">Bir ödev paylaşıldı</h1>
      <p class="module" id="module"></p>
      <p class="note" id="note"></p>

      <div class="rule"></div>

      <a class="btn btn-primary" id="open" href="#">Uygulamada aç</a>
      <a class="btn btn-secondary" href="/">Piyanomini nedir?</a>

      <p class="hint" id="hint">
        Açılmadıysa Piyanomini yüklü değil demektir. Uygulamayı yükledikten sonra bu bağlantıya yeniden dokun.
      </p>
    </main>

    <script define:vars={{ scheme }}>
      const TR = navigator.language?.toLowerCase().startsWith("tr") ?? true;
      const params = new URLSearchParams(location.search);
      const d = params.get("d");
      const note = params.get("n");

      // i18n metinleri
      if (!TR) {
        document.documentElement.lang = "en";
        document.getElementById("title").textContent = "An assignment was shared";
        document.getElementById("open").textContent = "Open in app";
        document.querySelector(".btn-secondary").textContent = "What is Piyanomini?";
        document.getElementById("hint").textContent =
          "If nothing opened, Piyanomini isn't installed. Install the app, then tap this link again.";
      }

      // Custom scheme fallback: app yüklüyse bu da açar (universal link tutmazsa).
      if (d) {
        // d artık tek base64url (deflate) blok — modül adını burada çözmüyoruz (app çözer).
        document.getElementById("open").href = `${scheme}://a?d=${encodeURIComponent(d)}`;
      } else {
        document.getElementById("open").style.display = "none";
      }
      if (note) document.getElementById("note").textContent = note;
    </script>
  </body>
</html>
